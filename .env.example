# Copy this file to .env and fill in your real key.
OPENAI_API_KEY=

# First-pass capture defaults to the OpenAI API.
OPENCLAW_CAPTURE_BACKEND=openai
OPENCLAW_CAPTURE_MODEL=gpt-5
OPENCLAW_CAPTURE_MAX_CHARS=120000

# Incremental updates default to the local OpenClaw backend.
OPENCLAW_UPDATE_BACKEND=openclaw
OPENCLAW_UPDATE_OPENAI_MODEL=gpt-5
OPENCLAW_UPDATE_MAX_CHARS=60000
